{
  "name": "supabase-axi",
  "version": "0.1.0",
  "packageManager": "pnpm@11.8.0",
  "description": "AXI-compliant Supabase CLI for agents — token-efficient TOON output, contextual suggestions, structured errors",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/maximebrmd/supabase-axi.git"
  },
  "keywords": [
    "supabase",
    "cli",
    "agent",
    "axi",
    "toon",
    "llm"
  ],
  "bin": {
    "supabase-axi": "./dist/bin/supabase-axi.js"
  },
  "files": [
    "dist",
    "skills/supabase-axi",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:skill": "tsx scripts/build-skill.ts",
    "dev": "tsx bin/supabase-axi.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "author": "Maxime Bourmaud (maximebrmd)",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axi-sdk-js": "^0.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  }
}
